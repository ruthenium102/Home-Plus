+// swift-tools-version: 5.9
+import PackageDescription
+
+let package = Package(
+    name: "CapacitorCommunitySpeechRecognition",
+    platforms: [.iOS(.v14)],
+    products: [
+        .library(
+            name: "CapacitorCommunitySpeechRecognition",
+            targets: ["CapacitorCommunitySpeechRecognitionPlugin"])
+    ],
+    dependencies: [
+        .package(url: "https://github.com/ionic-team/capacitor-swift-pm.git", from: "8.0.0")
+    ],
+    targets: [
+        .target(
+            name: "CapacitorCommunitySpeechRecognitionPlugin",
+            dependencies: [
+                .product(name: "Capacitor", package: "capacitor-swift-pm"),
+                .product(name: "Cordova", package: "capacitor-swift-pm")
+            ],
+            path: "ios/Plugin",
+            // The published 7.0.1 tarball still ships the legacy ObjC bridge
+            // (Plugin.h / Plugin.m). SwiftPM cannot mix C and Swift in one
+            // target, so compile ONLY Plugin.swift — it now self-registers via
+            // CAPBridgedPlugin, making the ObjC CAP_PLUGIN macro redundant.
+            sources: ["Plugin.swift"]
+        )
+    ]
